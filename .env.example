# SagaArchitect / LoreEngine — environment variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored; this file is committed as a reference.

# ─── AI generation ────────────────────────────────────────────────────────────
# Required for real AI story/lore generation. Without this, the app returns
# mock/placeholder content so you can still explore the UI.
OPENAI_API_KEY=

# ─── Rainstorms integration ───────────────────────────────────────────────────
# Base URL of the Rainstorms story-generation app.
# Used by the SagaArchitect "🌧 Sync to Rainstorms" button and the
# pingRainstorms() / syncToRainstorms() helpers in src/lib/rainstorms.ts.
# Example: http://localhost:8001  or  https://your-rainstorms-app.vercel.app
RAINSTORMS_BASE_URL=

# ─── Note: SAGA_ARCHITECT_BASE_URL (set in Rainstorms, not here) ──────────────
# Rainstorms reads the URL of this SagaArchitect deployment so it can call
# GET /api/universes/{id}/story-context before generating stories.
# Set this env var in the *Rainstorms* backend:
#
#   SAGA_ARCHITECT_BASE_URL=https://your-sagaarchitect.vercel.app
#   # or for local dev:
#   SAGA_ARCHITECT_BASE_URL=http://localhost:3000
